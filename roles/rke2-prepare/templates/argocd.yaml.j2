---
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: argocd
  namespace: kube-system
spec:
  chart: stable/argo-cd
  targetNamespace: argocd
  valuesContent: |-
    server:
      service:
        type: LoadBalancer
---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: helm-argocd-apps
  namespace: argocd
spec:
  project: default
  source:
    repoURL: {{ argo_repo }}
    targetRevision: HEAD
    path: {{ argo_repo_path }}
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
